rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if the user's email is whitelisted to access EMS
    function isEmailWhitelisted() {
      return isAuthenticated() && 
             request.auth.token.email != null &&
             request.auth.token.email.lower() in [
               'admin@lgltechnologies.com',
               'phani@lgltechnologies.com',
               'phanikanthkumar@gmail.com',
               'accounts@lgltechnologies.com',
               'srini@lgltechnologies.com'
             ];
    }

    // Employees Collection Rules
    match /employees/{employeeId} {
      allow read, write: if isEmailWhitelisted();
    }

    // Audit Activities Collection Rules
    match /activities/{activityId} {
      allow read, write: if isEmailWhitelisted();
    }

  }
}
